{
  "name": "board-game-boy",
  "private": true,
  "version": "0.1.0",
  "description": "Agentic Board Game Builder — turn a prompt into a browser-playable game",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --parallel build",
    "dev": "pnpm --filter @bgb/backend --filter @bgb/ui --parallel --stream dev",
    "dev:backend": "pnpm --filter @bgb/backend dev",
    "dev:ui": "pnpm --filter @bgb/ui dev",
    "dev:scaffold": "pnpm --filter @bgb/scaffold dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip --no-progress",
    "test": "pnpm -r --parallel test",
    "typecheck": "pnpm --filter @bgb/shared build && pnpm -r --filter '!@bgb/shared' --parallel typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "publish-bundle": "tsx scripts/publish-bundle.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.12.7",
    "eslint": "^9.13.0",
    "knip": "^5.36.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.12.0",
    "undici": "^6.19.2",
    "vitest": "^1.5.0"
  }
}
