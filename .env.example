# ── Backend (apps/backend) ────────────────────────────────────────────────────
# Fastify listen port; HF Spaces requires 7860 in production, 8787 is local default.
PORT=8787

# Persistent data directory: holds bgb.sqlite (langgraph checkpoints + fetch cache).
# Local default: ./.data | HF: /data | DigitalOcean: /var/data
DATA_DIR=./.data

# Bundle output directory (per-build folders under here).
BUNDLES_DIR=./bundles

# SQLite path (derived from DATA_DIR if unset).
SQLITE_PATH=

# CORS allow-list for the UI (comma-separated).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ollama base URL (only used if user picks the "ollama" provider in the UI).
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional provider base-URL overrides. Empty values mean "use the provider's
# public production endpoint". Override only when proxying or testing against a
# non-standard gateway.
GROQ_BASE_URL=
XAI_BASE_URL=

# Optional fallback API keys for *server-side* invocation. The Builder UI sends
# keys per-request via X-LLM-API-Key, which is the normal path. These env vars
# are only read if the per-request header is missing — useful for the `pnpm
# smoke` script and for CI runs that don't use the UI. Leave blank in dev.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=

# Log level: trace|debug|info|warn|error
LOG_LEVEL=info

# ── UI (apps/ui) ──────────────────────────────────────────────────────────────
# Where the UI sends its build requests. Local default points at the Fastify port above.
VITE_BACKEND_URL=http://localhost:8787

# ── Notes ─────────────────────────────────────────────────────────────────────
# LLM and search API keys are NOT stored here.
# They are entered in the UI Settings panel, kept in browser localStorage,
# and sent per-request as X-LLM-API-Key / X-SEARCH-API-Key headers.
