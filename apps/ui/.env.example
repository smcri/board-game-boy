# UI environment variables. Copy this to `.env.local` (which Vite reads
# automatically and which is git-ignored). Only variables prefixed with VITE_
# are exposed to the client bundle.

# Backend base URL. Defaults to current window origin if unset — that only
# works when the UI and backend are served from the same origin (e.g. via a
# reverse proxy in production). In local dev the backend lives on a separate
# port, so always set this.
VITE_BACKEND_URL=http://localhost:8787
