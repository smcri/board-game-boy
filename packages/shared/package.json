{
  "name": "@bgb/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ecs": {
      "import": "./dist/ecs.js",
      "types": "./dist/ecs.d.ts"
    },
    "./dsl": {
      "import": "./dist/dsl.js",
      "types": "./dist/dsl.d.ts"
    },
    "./rules": {
      "import": "./dist/rules.js",
      "types": "./dist/rules.d.ts"
    },
    "./assets": {
      "import": "./dist/assets.js",
      "types": "./dist/assets.d.ts"
    },
    "./bundle": {
      "import": "./dist/bundle.js",
      "types": "./dist/bundle.d.ts"
    },
    "./state": {
      "import": "./dist/state.js",
      "types": "./dist/state.d.ts"
    },
    "./sse": {
      "import": "./dist/sse.js",
      "types": "./dist/sse.d.ts"
    },
    "./providers": {
      "import": "./dist/providers.js",
      "types": "./dist/providers.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "echo \"(lint skipped for @bgb/shared)\""
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
